# ─── Database ────────────────────────────────────────────────────────────────
# Required: PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# For local development, run: docker compose up -d
DATABASE_URL="postgresql://sketchgit:dev_password@localhost:5432/sketchgit"

# ─── Auth (NextAuth / Auth.js v5) ─────────────────────────────────────────────
# Required: Random secret for signing JWT tokens (minimum 32 characters)
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-random-32-char-secret-here"

# Required: The canonical URL of your deployment (used for OAuth redirects)
NEXTAUTH_URL="http://localhost:3000"

# ─── OAuth Providers (optional) ───────────────────────────────────────────────
# GitHub OAuth – create an app at https://github.com/settings/developers
# Set the Authorization callback URL to: http://localhost:3000/api/auth/callback/github
GITHUB_ID=""
GITHUB_SECRET=""

# ─── Rate Limiting (P015) ─────────────────────────────────────────────────────
# Maximum requests per window per IP on auth endpoints (default: 10)
RATE_LIMIT_MAX=10
# Window size in seconds (default: 60)
RATE_LIMIT_WINDOW=60
# Set to "true" to disable rate limiting in test environments
# DISABLE_RATE_LIMIT=true

# ─── Presence Debouncing (P044) ───────────────────────────────────────────────
# Milliseconds to wait before broadcasting a presence update after a burst of
# connects/disconnects (default: 80). Set to 0 to disable debouncing.
# PRESENCE_DEBOUNCE_MS=80

# ─── WebSocket Security (P019) ────────────────────────────────────────────────
# Comma-separated list of allowed WebSocket origins (prevents CSWSH attacks).
# Defaults to NEXTAUTH_URL. Add your staging/preview URLs here if needed.
# WS_ALLOWED_ORIGINS=http://localhost:3000,https://staging.yourdomain.com

# ─── Optional – Redis (P012) ──────────────────────────────────────────────────
# Required for multi-instance deployments (horizontal scalability).
# When absent the server runs in single-process mode (no cross-instance relay).
# For local development with docker compose this is set automatically.
REDIS_URL=redis://localhost:6379

# ─── Room Pruning (P032) ──────────────────────────────────────────────────────
# Number of days of inactivity before a room is pruned (default: 30)
# PRUNE_INACTIVE_ROOMS_DAYS=30
# How often to run the pruning job, in hours (default: 24)
# PRUNE_INTERVAL_HOURS=24

# ─── Room Capacity Limit (P069) ───────────────────────────────────────────────
# Maximum WebSocket clients per room (default: 50). Reduce for low-memory deployments.
# MAX_CLIENTS_PER_ROOM=50

# ─── Prisma Slow-Query Logging (P071) ─────────────────────────────────────────
# Queries slower than this threshold (milliseconds) are logged at WARN level.
# Default: 500 ms. Set to 0 to log all queries.
# SLOW_QUERY_MS=500
#
# Set to "true" to log every Prisma query at DEBUG level (development only).
# LOG_QUERIES=true

# ─── WebSocket Per-Message Deflate Compression (P059) ─────────────────────────
# Minimum uncompressed message size (bytes) below which zlib compression is skipped.
# Default: 1024 (1 KB). Set to 0 to compress all messages (higher CPU usage).
# Compression reduces bandwidth for large canvas payloads by 60–80%.
# Memory: each compressed connection uses ~128 KB for the zlib context.
# WS_COMPRESSION_THRESHOLD=1024

# ─── Graceful Shutdown Drain Window (P043) ────────────────────────────────────
# Milliseconds to wait for in-flight DB writes before closing WebSocket
# connections on SIGTERM.  Set to 0 to disable drain (not recommended).
# SHUTDOWN_DRAIN_MS=5000

# ─── Password Reset Email (P040) ──────────────────────────────────────────────
# Optional: Resend API key for sending password-reset emails.
# If absent, tokens are generated but no email is sent (dev mode).
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# EMAIL_FROM="SketchGit <noreply@yourdomain.com>"

# ─── Runtime ──────────────────────────────────────────────────────────────────
# Port the server listens on (default: 3000)
# PORT=3000

# ─── Room Activity Feed (P074) ────────────────────────────────────────────────
# Number of days to retain RoomEvent audit-log rows. Rows older than this are
# deleted by the pruning job. Default: 90 days.
# ROOM_EVENT_RETENTION_DAYS=90

# ─── Room Invitation Tokens (P066) ───────────────────────────────────────────
# HMAC secret for signing invitation tokens. Falls back to AUTH_SECRET if unset.
# Must be at least 32 characters. Generate with: openssl rand -hex 32
# INVITATION_SECRET=your-invitation-secret-here-at-least-32-chars
